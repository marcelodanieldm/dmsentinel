# DM Sentinel - Environment Variables Configuration
# =================================================
# Copy this file to .env and fill with your actual credentials
# Never commit .env to git (already in .gitignore)

# ==================== STRIPE CONFIGURATION ====================

# Stripe API Key (get from: https://dashboard.stripe.com/apikeys)
# Use test key (sk_test_...) for development
# Use live key (sk_live_...) for production
STRIPE_API_KEY=sk_test_51...

# Stripe Webhook Secret (get from: https://dashboard.stripe.com/webhooks)
# This is used to verify webhook signatures
# Format: whsec_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ==================== TELEGRAM CONFIGURATION ====================

# Telegram Bot Token (get from: @BotFather on Telegram)
# Format: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram Chat ID (your personal chat ID or group chat ID)
# Get your Chat ID from: @userinfobot on Telegram
# For groups, use negative IDs: -1001234567890
# For personal chats, use positive IDs: 123456789
TELEGRAM_CHAT_ID=123456789

# ==================== GOOGLE SHEETS (OPTIONAL) ====================

# Path to Google Service Account credentials JSON file
# Get from: https://console.cloud.google.com/
GOOGLE_CREDENTIALS_PATH=credentials.json

# Default Google Spreadsheet ID for reports
# Get from URL: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
GOOGLE_SPREADSHEET_ID=1abc...xyz

# ==================== APPLICATION SETTINGS ====================

# Flask environment (development or production)
FLASK_ENV=development

# Flask debug mode (true or false)
FLASK_DEBUG=false

# Server host (0.0.0.0 for public access, 127.0.0.1 for localhost only)
FLASK_HOST=0.0.0.0

# Server port
FLASK_PORT=5000

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ==================== SECURITY SETTINGS ====================

# Enable/disable test endpoints in production (true or false)
# Set to false in production to disable /webhooks/stripe/test
ENABLE_TEST_ENDPOINTS=true

# API rate limiting (requests per minute)
API_RATE_LIMIT=60

# Maximum concurrent audits
MAX_CONCURRENT_AUDITS=5

# ==================== FEATURE FLAGS ====================

# Enable Google Sheets integration (true or false)
ENABLE_GOOGLE_SHEETS=false

# Enable PDF report generation (true or false)
ENABLE_PDF_REPORTS=true

# Enable historical tracking (true or false)
ENABLE_HISTORICAL_TRACKING=true

# Enable Telegram notifications (true or false)
ENABLE_TELEGRAM_NOTIFICATIONS=true

# ==================== NOTES ====================

# Loading environment variables in Python:
#
# Option 1: Using python-dotenv
#   pip install python-dotenv
#   from dotenv import load_dotenv
#   load_dotenv()
#
# Option 2: Manual export (Linux/Mac)
#   export STRIPE_API_KEY="sk_test_..."
#
# Option 3: PowerShell (Windows)
#   $env:STRIPE_API_KEY="sk_test_..."
#
# Option 4: System environment variables
#   Set permanently in OS settings

# Security Best Practices:
# - Never commit this file with real credentials
# - Rotate secrets regularly (at least every 90 days)
# - Use different credentials for dev/staging/production
# - Limit API key permissions to minimum required
# - Enable 2FA on all service accounts
# - Monitor for unauthorized access in service dashboards
