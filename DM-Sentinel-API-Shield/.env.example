# DM Sentinel API Shield - Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
HOST=0.0.0.0
PORT=8080
ENVIRONMENT=production

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# For Redis Cloud or managed services:
# REDIS_URL=redis://username:password@host:port/db

# Rate Limiting
DEFAULT_RATE_LIMIT=100  # requests per minute
DEFAULT_BURST_SIZE=20
RATE_LIMIT_WINDOW=60  # seconds

# Threat Detection
ENABLE_THREAT_DETECTION=true
ENABLE_SQL_INJECTION_DETECTION=true
ENABLE_NOSQL_INJECTION_DETECTION=true
ENABLE_COMMAND_INJECTION_DETECTION=true
ENABLE_PATH_TRAVERSAL_DETECTION=true

# Monitoring
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=9090
ENABLE_LOGGING=true
LOG_LEVEL=INFO

# Database (for analytics)
DATABASE_URL=postgresql://user:password@localhost:5432/api_shield

# External Services
# Sentry (error tracking)
SENTRY_DSN=

# Slack (alerts)
SLACK_WEBHOOK_URL=

# Email (alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL=security@dmglobal.com

# API Keys for external threat intelligence
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=

# Feature Flags
ENABLE_MACHINE_LEARNING=false
ENABLE_GEO_BLOCKING=false
ENABLE_CAPTCHA=false

# CORS
ALLOW_ORIGINS=*
ALLOW_CREDENTIALS=true

# Performance
MAX_WORKERS=4
REQUEST_TIMEOUT=30
MAX_REQUEST_SIZE=10485760  # 10MB
