# DM Sentinel RedTeam - Environment Variables
# Copy this file to .env and configure your values

# ==========================================
# Gophish Configuration
# ==========================================
GOPHISH_ADMIN_PASSWORD=ChangeMeNow123!
GOPHISH_DOMAIN=phish.dmsentinel.com

# ==========================================
# PostgreSQL Database
# ==========================================
POSTGRES_DB=moodle
POSTGRES_USER=moodleuser
POSTGRES_PASSWORD=MoodleSecure2024!

# ==========================================
# Moodle Configuration
# ==========================================
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=AdminSecure2024!
MOODLE_ADMIN_EMAIL=admin@dmsentinel.com
MOODLE_DOMAIN=training.dmsentinel.com

# ==========================================
# SMTP Configuration (SendGrid Example)
# ==========================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.your-sendgrid-api-key-here
SMTP_FROM_EMAIL=noreply@dmsentinel.com
SMTP_FROM_NAME=DM Sentinel Security Team

# Alternative SMTP providers:
# - AWS SES: email-smtp.us-east-1.amazonaws.com:587
# - Mailgun: smtp.mailgun.org:587
# - Gmail: smtp.gmail.com:587 (not recommended for production)

# ==========================================
# DNS Configuration
# ==========================================
PRIMARY_DOMAIN=dmsentinel.com
PHISHING_DOMAIN=securelink-verify.com
TRAINING_DOMAIN=training.dmsentinel.com

# Allowed sender domains (comma-separated)
ALLOWED_DOMAINS=dmsentinel.com,securelink-verify.com

# ==========================================
# Security Configuration
# ==========================================
# Session secret (generate with: openssl rand -base64 32)
SESSION_SECRET=your-random-session-secret-here

# JWT secret (generate with: openssl rand -base64 64)
JWT_SECRET=your-random-jwt-secret-here

# Encryption key for sensitive data (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-encryption-key-here

# ==========================================
# Server Configuration
# ==========================================
SERVER_IP=your.vps.ip.address
SERVER_TIMEZONE=America/New_York

# Reverse proxy configuration
ENABLE_HTTPS=true
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# ==========================================
# Logging Configuration
# ==========================================
LOG_LEVEL=info
LOG_RETENTION_DAYS=90
LOG_ENCRYPTION=true

# ==========================================
# Backup Configuration
# ==========================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPT=true

# ==========================================
# Monitoring & Alerts
# ==========================================
ALERT_EMAIL=security@dmsentinel.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_EMAILS_PER_HOUR=100
RATE_LIMIT_EMAILS_PER_DAY=1000

# ==========================================
# Feature Flags
# ==========================================
ENABLE_ANALYTICS=true
ENABLE_IP_LOGGING=true
ENABLE_GEOLOCATION=true
ENABLE_TWO_FACTOR=true

# ==========================================
# External Services
# ==========================================
# Mail checker API (mail-tester.com)
MAIL_TESTER_API_KEY=your-mail-tester-api-key

# IP reputation service
IPQUALITYSCORE_API_KEY=your-ipqs-api-key

# ==========================================
# Development/Staging (set to false in production)
# ==========================================
DEBUG_MODE=false
ALLOW_INSECURE_CONNECTIONS=false
