# DM Sentinel Landing Page - Environment Variables
# Copy this file to .env and fill in your actual keys

# ==================================================
# PAYMENT GATEWAY KEYS (PROMPT 2)
# ==================================================

# Stripe Public Key (get from https://dashboard.stripe.com/apikeys)
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_51...

# Mercado Pago Public Key (get from https://www.mercadopago.com.br/developers/panel/app)
REACT_APP_MERCADO_PAGO_PUBLIC_KEY=APP_USR-...

# Webhook URL (your backend endpoint)
REACT_APP_WEBHOOK_URL=https://api.dmsentinel.com/webhook/payment

# ==================================================
# OPTIONAL CONFIGURATIONS
# ==================================================

# Environment (development/production)
REACT_APP_ENV=development

# Analytics
REACT_APP_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
REACT_APP_HOTJAR_ID=XXXXXXX

# Social Links
REACT_APP_TWITTER_URL=https://twitter.com/dmsentinel
REACT_APP_GITHUB_URL=https://github.com/dmsentinel

# ==================================================
# SMART CONTRACT ADDRESSES (Web3 Payments)
# ==================================================

# DM Sentinel receiving wallet (replace with real address)
REACT_APP_DM_SENTINEL_WALLET=0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb

